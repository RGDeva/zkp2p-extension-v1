{
  "manifest_version": 3,
  "name": "XRamp: Crypto On/Off-Ramp via P2P Rails",
  "version": "0.0.8",
  "description": "Buy, sell, and send crypto instantly via Venmo, Cash App, Zelle and more — powered by XRamp",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_icon": "icon-32.png",
    "default_title": "Open XRamp"
  },
  "options_page": "options.html", 
  "background": {
    "service_worker": "background.bundle.js"
  },
  "side_panel": {
    "default_path": "sidePanel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.revolut.com/*",
        "https://zkp2p.xyz/*"
      ],
      "js": ["contentScript.bundle.js"],
      "css": ["content.styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.styles.css",
        "icon-48.png",
        "icon-32.png"
      ],
      "matches": [
        "https://app.revolut.com/*"
      ]
    }
  ],
  "host_permissions": [
    "https://xramp-app.vercel.app/*",
    "http://localhost:5173/*",
    "https://app.revolut.com/*",
    "https://zkp2p.xyz/*"
  ],
  "permissions": [
    "offscreen",
    "storage",
    "webRequest",
    "activeTab",
    "sidePanel",
    "tabs",
    "scripting"
  ]
}
